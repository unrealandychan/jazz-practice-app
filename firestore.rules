rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — authenticated users can read/write their own profile only
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Sessions — owner-scoped (deviceId matches UID for authenticated users)
    match /sessions/{sessionId} {
      allow read: if
        request.auth != null && resource.data.deviceId == request.auth.uid;

      allow create: if
        request.auth != null &&
        request.resource.data.deviceId == request.auth.uid;

      allow update, delete: if
        request.auth != null && resource.data.deviceId == request.auth.uid;
    }

    // Standards — public read, no client writes
    match /standards/{standardId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
